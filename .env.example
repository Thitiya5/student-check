# Firebase (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Apps Script Web App (students roster) — do not expose in UI
VITE_GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
# Alternative name (either works):
# VITE_GOOGLE_SCRIPT_URL=

# Optional shared secret if your GAS validates it
VITE_GAS_SECRET=

# Set to true only when ready for username + PIN login (default: name-only / legacy)
# VITE_ENABLE_PIN_LOGIN=true
