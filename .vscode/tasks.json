{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite-dev",
      "detail": "รัน Vite — Ctrl+คลิกที่ลิงก์ localhost ใน Terminal จะเปิดในแท็บเบราว์เซอร์ภายใน (ตั้งใน .vscode/settings.json)",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "vite",
          "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "(Local:|ready in)"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
